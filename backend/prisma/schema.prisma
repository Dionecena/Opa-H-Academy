// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  role      String   @default("user") // "user" ou "admin"
  createdAt DateTime @default(now())
  submissions   submissions[]
  comments      comments[]
  admin_webauthn_credentials admin_webauthn_credentials[]
  admin_sessions admin_sessions[]
}

model exercises {
  id        Int      @id @default(autoincrement())
  title     String
  type      String   // "exam" ou "practice"
  videoUrl  String?  @map("video_url")
  questions Json?    // Questions pour Hören/Lesen
  content   String?  // Contenu texte pour Lesen/Schreiben
  createdAt DateTime @default(now())
  @@map("exercises")
}

model speaking_words {
  id        Int      @id @default(autoincrement())
  word      String
  createdAt DateTime @default(now())
  @@map("speaking_words")
}

model themes {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
  @@map("themes")
}

model submissions {
  id        Int      @id @default(autoincrement())
  username  String
  type      String   // "audio" ou "text"
  context   String   // "sprechen", "schreiben", "practice"
  content   String   // texte ou chemin fichier audio
  createdAt DateTime @default(now())
  user      users    @relation(fields: [username], references: [username])
  comments  comments[]
  @@map("submissions")
}

model comments {
  id           Int      @id @default(autoincrement())
  submissionId Int      @map("submission_id")
  username     String
  content      String
  createdAt    DateTime @default(now())
  submission   submissions @relation(fields: [submissionId], references: [id])
  user         users       @relation(fields: [username], references: [username])
  @@map("comments")
}

model admin_webauthn_credentials {
  id           Int      @id @default(autoincrement())
  username     String
  credentialId String   @unique @map("credential_id")
  publicKey    String   @map("public_key")
  counter      Int      @default(0)
  createdAt    DateTime @default(now())
  user         users    @relation(fields: [username], references: [username])
  @@map("admin_webauthn_credentials")
}

model admin_sessions {
  id        Int      @id @default(autoincrement())
  username  String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now())
  user      users    @relation(fields: [username], references: [username])
  @@map("admin_sessions")
}
